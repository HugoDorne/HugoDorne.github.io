---
import PageLayout from "../layouts/PageLayout.astro";
---

<PageLayout title="404 — Page Not Found">
	<section class="flex min-h-[60vh] flex-col items-center justify-center py-20">
		<h1 class="text-6xl font-bold text-zinc-50">404</h1>
		<p class="mt-4 text-lg text-zinc-400">This page doesn't exist.</p>
		<a
			href="/"
			class="mt-8 rounded-lg bg-orange-400 px-6 py-3 text-sm font-medium text-zinc-950 transition-colors hover:bg-orange-500"
		>
			Go home
		</a>
	</section>
</PageLayout>
