---
const navLinks = [
	{ label: "Home", href: "/" },
	{ label: "Projects", href: "/projects" },
	{ label: "Blog", href: "/blog" },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 z-50 w-full border-b border-zinc-800/50 bg-zinc-950/80 backdrop-blur-sm">
	<div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6">
		<a href="/" class="text-lg font-bold text-zinc-50 transition-colors hover:text-orange-400">
			Hugo Dorne
		</a>

		<!-- Desktop nav -->
		<nav class="hidden items-center gap-8 md:flex">
			{
				navLinks.map((link) => (
					<a
						href={link.href}
						class:list={[
							"text-sm font-medium transition-colors",
							currentPath === link.href || (link.href !== "/" && currentPath.startsWith(link.href))
								? "text-orange-400"
								: "text-zinc-400 hover:text-zinc-50",
						]}
					>
						{link.label}
					</a>
				))
			}
		</nav>

		<!-- Mobile hamburger -->
		<button
			id="menu-toggle"
			class="flex h-10 w-10 items-center justify-center rounded-lg text-zinc-400 transition-colors hover:bg-zinc-800 hover:text-zinc-50 md:hidden"
			aria-label="Toggle menu"
		>
			<svg id="menu-icon-open" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
				<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
			</svg>
			<svg id="menu-icon-close" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
				<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
			</svg>
		</button>
	</div>

	<!-- Mobile menu -->
	<div id="mobile-menu" class="hidden border-t border-zinc-800/50 bg-zinc-950/95 backdrop-blur-sm md:hidden">
		<nav class="mx-auto flex max-w-6xl flex-col px-4 py-4 sm:px-6">
			{
				navLinks.map((link) => (
					<a
						href={link.href}
						class:list={[
							"rounded-lg px-4 py-3 text-base font-medium transition-colors",
							currentPath === link.href || (link.href !== "/" && currentPath.startsWith(link.href))
								? "bg-orange-400/10 text-orange-400"
								: "text-zinc-400 hover:bg-zinc-800 hover:text-zinc-50",
						]}
					>
						{link.label}
					</a>
				))
			}
		</nav>
	</div>
</header>

<script>
	const toggle = document.getElementById("menu-toggle");
	const menu = document.getElementById("mobile-menu");
	const iconOpen = document.getElementById("menu-icon-open");
	const iconClose = document.getElementById("menu-icon-close");

	toggle?.addEventListener("click", () => {
		const isOpen = !menu?.classList.contains("hidden");
		menu?.classList.toggle("hidden");
		iconOpen?.classList.toggle("hidden");
		iconClose?.classList.toggle("hidden");
	});
</script>
