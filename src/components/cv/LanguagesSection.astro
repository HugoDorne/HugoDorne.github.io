---
import SectionHeading from "../ui/SectionHeading.astro";
import { languages } from "../../data/cv";

const levelWidths: Record<string, string> = {
	Native: "w-full",
	Fluent: "w-5/6",
	Intermediate: "w-3/5",
	Beginner: "w-2/5",
	Notions: "w-1/5",
};
---

<section id="languages" class="animate-on-scroll py-16">
	<div class="mx-auto max-w-6xl px-4 sm:px-6">
		<SectionHeading title="Languages" />
		<div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
			{
				languages.map((lang) => (
					<div class="group rounded-xl border border-zinc-800 bg-zinc-900/50 p-5">
						<div class="flex items-baseline justify-between">
							<div class="flex items-baseline gap-2">
							<h3 class="text-base font-semibold text-zinc-50">{lang.name}</h3>
							<span class="text-xs italic text-orange-400/70 opacity-0 transition-opacity duration-300 group-hover:opacity-100">{lang.hello}</span>
						</div>
							<span class="text-sm text-zinc-500">
								{lang.level}
								{lang.details && ` (${lang.details})`}
							</span>
						</div>
						<div class="mt-3 h-1.5 w-full rounded-full bg-zinc-800">
							<div class:list={["h-1.5 rounded-full bg-orange-400", levelWidths[lang.level] || "w-1/5"]}></div>
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>
