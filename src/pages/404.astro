---
import PageLayout from "../layouts/PageLayout.astro";
---

<PageLayout title="404 — Page Not Found">
	<section class="flex min-h-[60vh] flex-col items-center justify-center py-20 text-center">
		<p class="text-8xl">👻</p>
		<h1 class="mt-6 text-7xl font-bold text-zinc-50">404</h1>
		<p class="mt-4 text-lg text-zinc-400">You've wandered into the void.</p>
		<p class="mt-1 text-sm text-zinc-600">There's nothing here... yet.</p>
		<a
			href="/"
			class="mt-8 inline-flex items-center gap-2 rounded-lg border border-zinc-700 px-6 py-3 text-sm font-medium text-zinc-300 transition-all hover:border-orange-400/40 hover:text-orange-400"
		>
			<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
				<path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
			</svg>
			Take me home
		</a>
	</section>
</PageLayout>
