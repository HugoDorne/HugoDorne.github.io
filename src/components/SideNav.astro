---
const sections = [
	{ id: "about", label: "About" },
	{ id: "experience", label: "Experience" },
	{ id: "education", label: "Education" },
	{ id: "skills", label: "Tech Stack" },
	{ id: "certifications", label: "Certifications" },
	{ id: "languages", label: "Languages" },
];
---

<nav id="side-nav" class="fixed left-6 top-1/2 z-40 hidden -translate-y-1/2 xl:flex flex-col items-start gap-1">
	{
		sections.map((section) => (
			<a
				href={`#${section.id}`}
				data-section={section.id}
				class="side-nav-link group flex items-center gap-3 rounded-lg px-3 py-1.5 text-sm text-zinc-600 transition-all duration-200 hover:text-zinc-300"
			>
				<span class="h-1.5 w-1.5 rounded-full bg-zinc-700 transition-all duration-200 group-hover:bg-zinc-400" />
				<span class="transition-all duration-200">{section.label}</span>
			</a>
		))
	}
</nav>

<script>
	const links = document.querySelectorAll<HTMLAnchorElement>(".side-nav-link");
	const sections = Array.from(links).map((link) => {
		const id = link.dataset.section!;
		return { id, el: document.getElementById(id)!, link };
	});

	function updateActive() {
		const scrollY = window.scrollY + window.innerHeight / 3;

		let activeId = sections[0].id;
		for (const section of sections) {
			if (section.el && section.el.offsetTop <= scrollY) {
				activeId = section.id;
			}
		}

		links.forEach((link) => {
			const dot = link.querySelector("span:first-child")!;
			const label = link.querySelector("span:last-child")!;
			if (link.dataset.section === activeId) {
				link.classList.remove("text-zinc-600");
				link.classList.add("text-orange-400");
				dot.classList.remove("bg-zinc-700");
				dot.classList.add("bg-orange-400", "scale-125");
				label.classList.add("font-medium");
			} else {
				link.classList.add("text-zinc-600");
				link.classList.remove("text-orange-400");
				dot.classList.add("bg-zinc-700");
				dot.classList.remove("bg-orange-400", "scale-125");
				label.classList.remove("font-medium");
			}
		});
	}

	window.addEventListener("scroll", updateActive, { passive: true });
	updateActive();
</script>
