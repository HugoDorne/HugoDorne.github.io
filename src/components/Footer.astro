---
const navLinks = [
	{ label: "Home", href: "/" },
	{ label: "Projects", href: "/projects" },
	{ label: "Blog", href: "/blog" },
];

const socialLinks = [
	{ label: "GitHub", href: "https://github.com/HugoDorne", icon: "github" },
	{ label: "LinkedIn", href: "https://www.linkedin.com/in/hugodorne/", icon: "linkedin" },
	{ label: "Email", href: "mailto:hugodorne@gmail.com", icon: "email" },
];
---

<footer class="border-t border-zinc-800/50 bg-zinc-950">
	<div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
		<div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
			<!-- Brand -->
			<div>
				<a href="/" class="text-lg font-bold text-zinc-50">Hugo Dorne</a>
				<p class="mt-2 text-sm text-zinc-500">
					Senior Software Engineer<br />Full Stack & AI developments
				</p>
			</div>

			<!-- Navigation -->
			<div>
				<h3 class="text-sm font-semibold text-zinc-50">Navigation</h3>
				<ul class="mt-3 space-y-2">
					{
						navLinks.map((link) => (
							<li>
								<a href={link.href} class="text-sm text-zinc-400 transition-colors hover:text-orange-400">
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>

			<!-- Social -->
			<div>
				<h3 class="text-sm font-semibold text-zinc-50">Connect</h3>
				<ul class="mt-3 space-y-2">
					{
						socialLinks.map((link) => (
							<li>
								<a
									href={link.href}
									target={link.icon !== "email" ? "_blank" : undefined}
									rel={link.icon !== "email" ? "noopener noreferrer" : undefined}
									class="text-sm text-zinc-400 transition-colors hover:text-orange-400"
								>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</div>

		<div class="mt-10 border-t border-zinc-800/50 pt-6 text-center text-sm text-zinc-600">
			&copy; {new Date().getFullYear()} Hugo Dorne. All rights reserved.
		</div>
	</div>
</footer>
