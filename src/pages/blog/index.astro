---
import PageLayout from "../../layouts/PageLayout.astro";
import BlogPostCard from "../../components/BlogPostCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<PageLayout title="Blog — Hugo Dorne">
	<section class="py-20">
		<div class="mx-auto max-w-6xl px-4 sm:px-6">
			<h1 class="text-3xl font-bold text-zinc-50 md:text-4xl">Blog</h1>
			<p class="mt-3 text-base text-zinc-400">Thoughts on software engineering, AI, and tech.</p>

			{
				posts.length === 0 ? (
					<p class="mt-10 text-zinc-500">No posts yet. Stay tuned!</p>
				) : (
					<div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
						{posts.map((post) => (
							<BlogPostCard
								title={post.data.title}
								description={post.data.description}
								pubDate={post.data.pubDate}
								tags={post.data.tags}
								slug={post.slug}
							/>
						))}
					</div>
				)
			}
		</div>
	</section>
</PageLayout>
