---
import SectionHeading from "../ui/SectionHeading.astro";
import { education } from "../../data/cv";
---

<section class="py-16">
	<div class="mx-auto max-w-6xl px-4 sm:px-6">
		<SectionHeading title="Education" />
		<div class="ml-1">
			{
				education.map((edu) => (
					<div class="relative pl-8 pb-10 last:pb-0">
						<div class="absolute top-2 left-0 bottom-0 w-px bg-zinc-800"></div>
						<div class="absolute top-2 left-0 -translate-x-1/2 h-3 w-3 rounded-full border-2 border-orange-400 bg-zinc-950"></div>
						<div>
							<h3 class="text-lg font-semibold text-zinc-50">{edu.institution}</h3>
							<p class="mt-1 text-sm font-medium text-orange-400">{edu.degree}</p>
							<p class="mt-0.5 text-sm text-zinc-500">{edu.startYear} — {edu.endYear}</p>
							{edu.details && <p class="mt-2 text-sm text-zinc-400">{edu.details}</p>}
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>
